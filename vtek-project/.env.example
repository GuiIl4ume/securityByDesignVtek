# Copiez ce fichier en .env et renseignez vos valeurs
# Ne committez JAMAIS le fichier .env dans git

POSTGRES_USER=vtek_user
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=vtek_db
DATABASE_URL=postgresql://vtek_user:CHANGE_ME_IN_PRODUCTION@db:5432/vtek_db

# Grafana — interface de supervision (http://localhost:3000)
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION
